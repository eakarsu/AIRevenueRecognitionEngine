PORT=3001
CLIENT_URL=http://localhost:3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=revenue_recognition
JWT_SECRET=replace-with-a-long-random-secret

# OpenRouter AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# NetSuite RESTlet connector
NETSUITE_BASE_URL=https://ACCOUNT_ID.restlets.api.netsuite.com
NETSUITE_ACCESS_TOKEN=
NETSUITE_ACCOUNT_ID=
NETSUITE_RESTLET_SCRIPT_ID=
NETSUITE_RESTLET_DEPLOY_ID=

# SAP OData connector
SAP_ODATA_BASE_URL=https://your-sap-host.example.com
SAP_BEARER_TOKEN=
SAP_CLIENT=
SAP_COMPANY_CODE=

# Salesforce REST connector
SALESFORCE_INSTANCE_URL=https://your-domain.my.salesforce.com
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_API_VERSION=v60.0

# Notification delivery
NOTIFICATION_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# SMTP notification delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICATION_EMAIL_TO=
